---
import type { albumProps } from "src/types";

interface Props {
  album: albumProps;
  hasTransition: boolean;
}
const { album, hasTransition } = Astro.props;
---

<li
  class="flex-[0_0_9rem] rounded-lg color-[rgba(var(--content),1)] duration-150 gap-2"
>
  <a
    class="flex flex-col rounded-lg color-[rgba(var(--content),1)] duration-150 gap-2"
    href={`/album/${album.id}`}
  >
    <img
      src={album.image}
      alt="yoasobi song"
      class="object-fill aspect-square w-full rounded-md"
      transition:name={hasTransition ? `${album.id}-to-page` : undefined}
    />
    <h2 class="font-normal text-[18px] m-0 leading-5">
      {album.name}
    </h2>
    <span class="text-xs font-medium opacity-70">
      {album.artist?.name}
    </span>
  </a>
</li>

<style>
  @media (hover: hover) {
    li:hover {
      background-color: rgba(var(--bg-contrast), 0.4);
    }
  }
</style>
