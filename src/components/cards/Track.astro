---
import { Image } from "astro:assets";
import type { trackProps } from "./../../types";
export const prerender = false;

interface Props {
  track: trackProps;
  hasTransition?: boolean;
  size: "sm" | "lg";
}

const { track, hasTransition, size } = Astro.props;
---

<li
  class="w-96 rounded-lg color-[rgba(var(--content),1)] duration-150 gap-2 active:scale-[.98] active:opacity-80 relative"
  class:list={size === "sm" ? "flex-[0_0_7rem] " : "flex-[0_0_10rem] "}
  transition:name={hasTransition ? `${track.id}-to-background` : undefined}
>
  <a
    id={track.id}
    class="flex flex-col rounded-lg color-[rgba(var(--content),1)] duration-150 gap-2 track"
    href={`/track/${track.id}`}
  >
    <Image
      src={track.image}
      alt={track.name}
      width={10}
      height={10}
      class="object-fill aspect-square w-full rounded-md"
      transition:name={`${track.id}-to-page`}
      loading="lazy"
      quality={"low"}
    />
    <h2
      style={{ overflowWrap: "anywhere" }}
      class="font-normal text-base m-0 leading-5"
      transition:name={hasTransition ? `${track.id}-to-title` : undefined}
    >
      {track.name}
    </h2>
    <span
      class="text-xs font-medium opacity-70"
      transition:name={hasTransition ? `${track.id}-to-artist` : undefined}
    >
      {track.artist?.name}
    </span>
  </a>
</li>

<style>
  @media (hover: hover) {
    li:hover {
      background-color: rgba(var(--bg-contrast), 0.4);
    }
  }
</style>
<script>
  const touchElements = document.querySelector("content-bg");
  console.log(touchElements);
  touchElements?.addEventListener("click", function (this: Element, e: any) {
    let x = e.offsetX;
    let y = e.offsetY;
    console.log(e);
    let ripples = document.createElement("span");
    ripples.classList.add("ripple");
    ripples.style.left = x + "px";
    ripples.style.top = y + "px";
    this.appendChild(ripples);

    setTimeout(() => ripples.remove(), 500);
  });
</script>
