---
interface Props {
  artist: {
    image: string;
    name: string;
  };
  newRelease: {
    name: string;
    image: string;
    id: string;
    type: "album" | "track";
  };
}
const { artist, newRelease } = Astro.props;
---

<section class="flex flex-col gap-5 pt-8">
  <h2 class="text-lg font-extrabold">Selección del artista</h2>
  <a
    class="flex flex-col w-full h-52 relative"
    href={`/track/${newRelease.id}`}
  >
    <img
      src={newRelease.image}
      alt={newRelease.name}
      class="w-full h-full opacity-50 object-cover rounded-md"
    />
    <header
      class="flex items-center absolute top-4 left-4 gap-2 bg-white rounded-full text-black font-medium text-xs py-[2px] pl-[2px] pr-2 leading-none"
    >
      <img
        src={artist.image}
        alt={artist.name}
        class="w-6 h-6 rounded-full object-cover"
      />
      Nuevo lanzamiento 🎸
    </header>
    <footer
      class="flex justify-center items-center absolute bottom-4 left-4 gap-3"
    >
      <img
        src={newRelease.image}
        alt={newRelease.name}
        class="w-12 h-12 object-fill"
      />
      <div class="flex flex-col leading-none gap-1">
        <h2 class="text-base leading-none font-semibold">{newRelease.name}</h2>
        <span class="text-xs leading-none opacity-85">
          {
            newRelease.type === "track"
              ? `Sencillo • Nuevos lanzamientos`
              : `Álbum • Nuevos lanzamientos`
          }
        </span>
      </div>
    </footer>
  </a>
</section>
