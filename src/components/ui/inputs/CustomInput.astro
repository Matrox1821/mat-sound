---
interface Props {
  title: string;
  isRequired: boolean;
  name: string;
  type: string;
}

const { title, isRequired, name, type = "text" } = Astro.props;
---

{
  type === "text" && (
    <label class="flex flex-col gap-2">
      <h2 class="flex">
        {title}
        {isRequired && <span class="text-red-400 pl-1">*</span>}
      </h2>
      <input
        type="text"
        value="none"
        name={name}
        required={isRequired}
        class="bg-[rgba(var(--bg))] border-2 border-[rgba(var(--content),.7)] rounded-md h-8 focus-visible:border-[rgba(var(--accent),.9)] focus:border-2 outline-none py-4 pl-1"
      />
    </label>
  )
}

{
  type === "textarea" && (
    <label class="flex flex-col gap-2">
      <h2 class="flex">
        {title}
        {isRequired && <span class="text-red-400 pl-1">*</span>}
      </h2>
      <textarea
        name={name}
        value="none"
        required={isRequired}
        class="bg-[rgba(var(--bg))] border-2 border-[rgba(var(--content),.7)] rounded-md h-16 focus-visible:border-[rgba(var(--accent),.9)] focus:border-2 outline-none py-1 pl-1"
      />
    </label>
  )
}
{
  type === "checkbox" && (
    <label class="inline-flex gap-2 items-center">
      <h2 class="flex">{title}</h2>
      {isRequired && <span class="text-red-400 pl-1">*</span>}
      <input
        type="checkbox"
        value="none"
        name={name}
        required={isRequired}
        class="bg-[rgba(var(--bg))] border-2 border-[rgba(var(--content),.7)] rounded-md h-8 focus-visible:border-[rgba(var(--accent),.9)] focus:border-2 outline-none py-4 pl-1"
      />
    </label>
  )
}
