---
const links = [
  {
    name: "Inicio",
    url: "/",
    Icon: (await import(`./icons/Home.astro`)).default,
    SolidIcon: (await import(`./icons/HomeSolid.astro`)).default,
  },
  {
    name: "Buscar",
    url: "/search",
    Icon: (await import(`./icons/Search.astro`)).default,
    SolidIcon: (await import(`./icons/SearchSolid.astro`)).default,
  },
  {
    name: "Biblioteca",
    url: "/library",
    Icon: (await import(`./icons/Library.astro`)).default,
    SolidIcon: (await import(`./icons/LibrarySolid.astro`)).default,
  },
];
const pathname = Astro.url.pathname;
---

<nav class="w-full h-16 fixed bottom-0 z-[50] flex justify-around">
  <span
    style={{
      background:
        " linear-gradient(to top, rgba(0,0,0,1) 0%,rgba(0,0,0,0.85) 30%, rgba(0,0,0,0.5) 70%, rgba(255,255,255,0) 100%)",
    }}
    class="w-full h-28 fixed bottom-0 z-[49]"></span>
  {
    links.map(({ name, url, Icon, SolidIcon }) => (
      <a href={url} class="flex flex-col items-center w-24 relative z-50">
        <span>{pathname === url ? <SolidIcon /> : <Icon />}</span>
        <span class:list={pathname === url ? "font-semibold" : ""}>{name}</span>
      </a>
    ))
  }
</nav>
