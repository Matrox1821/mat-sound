---
import { ColumnCard } from "@components/cards/ColumnCard";
import Track from "@components/cards/Track.astro";
import { getTracks, getTracksByArtistId } from "src/queryFn";
import type { trackProps } from "src/types";

interface Props {
  hasTransition?: boolean;
  type: "row" | "column";
  isPlaylist?: boolean;
  artistId?: string;
  albumId?: string;
}
const {
  hasTransition = false,
  type,
  isPlaylist = false,
  artistId,
  albumId,
} = Astro.props;

let tracks;

if (artistId) {
  const { data } = await getTracksByArtistId(artistId);
  if (!data) return;
  tracks = data.tracks;
}

/* if (albumId) {
  const { data } = await getTracksByAlbumId(albumId);
  if (!data) return;
  tracks = data.tracks;
}
 */
if (!artistId && !albumId) {
  const { data: tracksData } = await getTracks();

  if (!tracksData) return;
  tracks = tracksData.tracks;
}
---

<ul class="flex overflow-x-auto overflow-y-hidden gap-4 p-2">
  {
    type === "row" &&
      tracks?.map((track: trackProps) => (
        <Track track={track} hasTransition={hasTransition} />
      ))
  }
</ul>
<ul class="flex flex-col overflow-x-auto overflow-y-hidden gap-4 p-2">
  {
    type === "column" &&
      tracks?.map((track: trackProps) => (
        <ColumnCard
          track={track}
          tracks={tracks}
          isPlaylist={isPlaylist}
          client:load
        />
      ))
  }
</ul>
