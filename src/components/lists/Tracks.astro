---
import { ColumnCard } from "@components/cards/ColumnCard";
import Track from "@components/cards/Track.astro";
import {
  getTracks,
  getTracksByArtistId,
  getTracksByAlbumId,
} from "src/queryFn";
import { sortArray } from "src/shared/helpers";
import type { trackProps } from "src/types";

interface Props {
  hasTransition?: boolean;
  type: "row" | "column";
  isPlaylist?: boolean;
  artistId?: string;
  albumId?: string;
  trackId?: string;
  maxTracks?: number;
  isRecomendation?: boolean;
}
const {
  hasTransition = false,
  type,
  isPlaylist = false,
  artistId,
  albumId,
  maxTracks = 7,
  isRecomendation = false,
  trackId,
} = Astro.props;

let tracks;

if (artistId && !isRecomendation) {
  const { data } = await getTracksByArtistId(artistId);
  if (!data) return;
  tracks = sortArray(data.tracks);
}
if (albumId && !isRecomendation) {
  const { data } = await getTracksByAlbumId(albumId);
  if (!data) return;
  /*  console.log(data.tracks); */
  tracks = data.tracks;
}
if ((!artistId && !albumId) || isRecomendation) {
  const { data } = await getTracks();

  if (!data) return;
  tracks = isPlaylist ? data.tracks : sortArray(data.tracks);
}

if (isRecomendation) {
  if (artistId) {
    tracks = tracks?.filter((newTrack) => newTrack.artist?.id !== artistId);
  }
  if (albumId) {
    tracks = tracks?.filter((newTrack) => newTrack.album?.id !== albumId);
  }
  if (trackId) {
    tracks = tracks?.filter((newTrack) => newTrack?.id !== trackId);
  }
}
tracks = tracks?.slice(0, maxTracks);
const listStyle =
  type === "row"
    ? "flex overflow-x-auto overflow-y-hidden gap-4 p-2"
    : "flex flex-col overflow-x-auto overflow-y-hidden gap-2 p-2";
---

<ul class={listStyle}>
  {
    type === "column"
      ? tracks?.map((track: trackProps) => (
          <ColumnCard
            track={track}
            tracks={tracks}
            isPlaylist={isPlaylist}
            client:load
          />
        ))
      : tracks?.map((track: trackProps) => (
          <Track track={track} hasTransition={hasTransition} />
        ))
  }
</ul>
