---
import AdminLayout from "@layouts/AdminLayout.astro";
---

<AdminLayout title="Admin - Mat Sound">
  <main
    class="w-[350px] rounded-lg border-2 border-[rgba(var(--accent),.4)] p-8 flex flex-col gap-8"
  >
    <a href="/admin/create/tracks" class="text-2xl font-semibold cursor-pointer"
      >Agregar Cancion</a
    >
    <a href="/admin/create/albums" class="text-2xl font-semibold cursor-pointer"
      >Agregar Album</a
    >
    <a
      href="/admin/create/artists"
      class="text-2xl font-semibold cursor-pointer">Agregar Artista</a
    >
  </main>
</AdminLayout>
