---
import NavBar from "@components/NavBar.astro";
import { ClientRouter } from "astro:transitions";
import { PlayerBar } from "@components/player/PlayerBar.tsx";
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <NavBar transition:persist />
    <main
      class="w-screen relative px-4 flex flex-col gap-4 pt-4 pb-20 overflow-hidden"
    >
      <slot />
    </main>
    <PlayerBar client:load transition:name="media-player" transition:persist />
  </body>
</html>

<style is:global>
  :root {
    --content: 250, 250, 255;
    --accent: 103, 125, 255;
    --bg: 18, 18, 18;
    --bg-contrast: 34, 35, 84;
  }
  * {
    font-family:
      Plus Jakarta Sans,
      sans-serif;
    font-optical-sizing: auto;
    box-sizing: border-box;
  }
  html {
  }
  li,
  ul {
    list-style: none;
  }
  h1,
  h2,
  h3,
  h4 {
    text-wrap: balance;
  }
  p {
    text-wrap: pretty;
  }
  code {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }
  body {
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
    font-family: system-ui, sans-serif;
    background: rgba(var(--bg), 1);
    color: rgba(var(--content));
  }
  .player-screen {
    position: fixed;
    width: 100vw;
    height: 100vh;
    transition: transform 300ms ease-in 0s;
    top: 100vh;
    z-index: 100;
    &:not(.is-closed) {
      transform: translateY(-100vh);
    }
  }
  .scroll-current-music {
    display: flex;
    overflow-x: scroll;
    overscroll-behavior-x: contain;
    white-space: nowrap;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    &::-webkit-scrollbar {
      background: transparent;
      width: 0px;
    }
    & > div {
      position: relative;
      scroll-snap-align: center;
    }
  }
  .image-button {
    color: rgb(192, 192, 192);
    &::after {
      content: "";
      position: absolute;
      width: 4rem;
      height: 4rem;
      background: conic-gradient(
        rgb(190, 190, 190) var(--angle),
        transparent 0deg 360deg
      );
      z-index: 10;
      animation:
        border-right 3s linear,
        border-completed 3s forwards;
    }
    &::before {
      content: "";
      position: absolute;
      width: 4rem;
      height: 4rem;
      background-image: conic-gradient(
        rgb(190, 190, 190) var(--angle2),
        transparent 0deg 360deg
      );
      z-index: 10;
      animation: border-left 2.5s linear;
      transform: rotate(180deg);
    }
  }
  @keyframes border-right {
    0% {
      --angle: 40deg;
      transform: rotate(0deg);
    }
    33% {
      --angle: 70deg;
    }
    66% {
      --angle: 200deg;
    }
    100% {
      transform: rotate(360deg);

      --angle: 360deg;
    }
  }
  @keyframes border-left {
    0% {
      --angle2: 40deg;
    }
    100% {
      transform: rotate(540deg);

      --angle2: 360deg;
    }
  }
  @keyframes border-completed {
    0%,
    99% {
    }
    100% {
      --angle: 360deg;
    }
  }

  @property --angle {
    syntax: "<angle>"; /* this can be angle or percentage */
    initial-value: 0deg;
    inherits: false;
  }
  @property --angle2 {
    syntax: "<angle>"; /* this can be angle or percentage */
    initial-value: 0deg;
    inherits: false;
  }

  .skeleton {
    &::before,
    &::after {
      content: "";
      background-color: rgba(255, 255, 255, 0.4);
      position: absolute;
      rotate: 20deg;
      animation: shine 1.5s infinite;
    }

    &.skeleton-box {
      &::before,
      &::after {
        top: -100px;
        height: 300%;
      }
      &::before {
        width: 5%;
        left: -6rem;
      }
      &::after {
        width: 15%;
        left: -4.5rem;
      }
    }
    &.skeleton-text {
      &::before,
      &::after {
        bottom: 0px;
        height: 8rem;
      }
      &::before {
        width: 5%;
        left: -6rem;
      }
      &::after {
        width: 15%;
        left: -4.5rem;
      }
    }
    &.skeleton-span {
      &::before,
      &::after {
        bottom: 24px;
        height: 8rem;
      }
      &::before {
        width: 5%;
        left: -6rem;
      }
      &::after {
        width: 15%;
        left: -4.5rem;
      }
    }
  }
  .skeleton-col {
    &::before,
    &::after {
      content: "";
      background-color: rgba(255, 255, 255, 0.4);
      position: absolute;
      rotate: 20deg;
    }
    &.skeleton-box {
      &::before,
      &::after {
        top: -2rem;
        height: 5rem;
        animation: box-col-shine 1.5s infinite;
      }
      &::before {
        width: 7%;
        left: -1.6rem;
      }
      &::after {
        width: 15%;
        left: -1rem;
      }
    }
    &.skeleton-col-text {
      &::before,
      &::after {
        top: -15rem;
        height: 15rem;
        animation: text-col-shine 1.5s infinite;
      }
      &::before {
        width: 1%;
        left: -6rem;
      }
      &::after {
        width: 5%;
        left: -5rem;
      }
    }
  }
  @keyframes box-col-shine {
    to {
      transform: translateX(8rem);
    }
  }
  @keyframes text-col-shine {
    to {
      transform: translateX(30rem);
    }
  }
  @keyframes shine {
    to {
      transform: translateX(17rem);
    }
  }
</style>
