---
import NavBar from "../components/NavBar.astro";
import { ClientRouter } from "astro:transitions";
import { PlayerBar } from "../components/player/PlayerBar.tsx";
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <NavBar />
    <slot />
    <PlayerBar client:load transition:name="media-player" transition:persist />
  </body>
</html>

<style is:global>
  :root {
    --content: 250, 250, 255;
    --accent: 103, 125, 255;
    --bg: 4, 11, 23;
    --bg-contrast: 34, 35, 84;
  }
  * {
    box-sizing: border-box;
  }
  html {
  }
  li,
  ul {
    list-style: none;
  }
  h1,
  h2,
  h3,
  h4 {
    text-wrap: balance;
  }
  p {
    text-wrap: pretty;
  }
  code {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }
  body {
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
    font-family: system-ui, sans-serif;
    background: rgba(var(--bg), 1);
    color: rgba(var(--content));
  }
  .player-screen {
    position: fixed;
    width: 100vw;
    height: 100vh;
    transition: transform 300ms ease-in 0s;
    top: 100vh;
    z-index: 100;
    &:not(.is-closed) {
      transform: translateY(-100vh);
    }
  }
</style>
